{
  "name": "library-attendance-api",
  "version": "1.0.0",
  "description": "REST API sistem kehadiran dan poin pengunjung perpustakaan",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:up": "node-pg-migrate -e NODE_ENV up",
